            "custom_liquid": "{% comment %}\n  ✅ BUNDLE & SAVE — Sobre noir & blanc\n{% endcomment %}\n\n<script>\n  var BUNDLE_VARIANTS = {};\n  {% for variant in product.variants %}\n    BUNDLE_VARIANTS[\"{{ variant.title | downcase | strip }}\"] = {\n      id: {{ variant.id }},\n      price: {{ variant.price | times: 1.0 | divided_by: 100.0 }}\n    };\n  {% endfor %}\n</script>\n\n<style>\n  .bsw {\n    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;\n    margin: 14px 0;\n    width: 100%;\n  }\n\n  .bsw-divider {\n    display: flex;\n    align-items: center;\n    gap: 10px;\n    margin-bottom: 14px;\n  }\n  .bsw-divider-line { flex: 1; height: 1px; background: #e5e5e5; }\n  .bsw-divider-text {\n    font-size: 10px;\n    font-weight: 700;\n    letter-spacing: 0.14em;\n    text-transform: uppercase;\n    color: #999;\n    white-space: nowrap;\n  }\n\n  .bsw-options { display: flex; flex-direction: column; gap: 8px; }\n\n  .bsw-option {\n    position: relative;\n    border: 1.5px solid #e8e8e8;\n    border-radius: 12px;\n    padding: 13px 15px;\n    cursor: pointer;\n    transition: border-color 0.15s, background 0.15s;\n    background: #fff;\n    user-select: none;\n  }\n  .bsw-option:hover { border-color: #c0c0c0; }\n  .bsw-option.selected {\n    border-color: #1a1a1a;\n    background: #fafafa;\n    cursor: default;\n  }\n\n  .bsw-option-row {\n    display: flex;\n    align-items: center;\n    gap: 12px;\n  }\n\n  .bsw-radio {\n    flex-shrink: 0;\n    width: 18px;\n    height: 18px;\n    border-radius: 50%;\n    border: 2px solid #d0d0d0;\n    background: #fff;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    transition: border-color 0.15s, background 0.15s;\n  }\n  .bsw-option.selected .bsw-radio {\n    border-color: #1a1a1a;\n    background: #1a1a1a;\n  }\n  .bsw-radio-dot {\n    width: 7px;\n    height: 7px;\n    border-radius: 50%;\n    background: #fff;\n    opacity: 0;\n    transform: scale(0.3);\n    transition: opacity 0.15s, transform 0.15s;\n  }\n  .bsw-option.selected .bsw-radio-dot { opacity: 1; transform: scale(1); }\n\n  .bsw-info { flex: 1; min-width: 0; }\n\n  .bsw-qty {\n    font-size: 13.5px;\n    font-weight: 700;\n    color: #1a1a1a;\n    margin-bottom: 3px;\n    display: flex;\n    align-items: center;\n    flex-wrap: wrap;\n    gap: 6px;\n  }\n\n  .bsw-per-unit {\n    font-size: 11.5px;\n    color: #999;\n  }\n\n  .bsw-pricing { text-align: right; flex-shrink: 0; }\n  .bsw-price {\n    font-size: 15px;\n    font-weight: 700;\n    color: #1a1a1a;\n    display: block;\n  }\n  .bsw-original {\n    font-size: 12px;\n    color: #bbb;\n    text-decoration: line-through;\n    display: block;\n  }\n\n  /* Badge populaire */\n  .bsw-badge {\n    position: absolute;\n    top: -11px;\n    right: 14px;\n    background: #1a1a1a;\n    color: #fff;\n    font-size: 10px;\n    font-weight: 700;\n    letter-spacing: 0.08em;\n    text-transform: uppercase;\n    padding: 3px 10px;\n    border-radius: 20px;\n  }\n\n  /* Tags */\n  .bsw-tag {\n    display: inline-block;\n    font-size: 10px;\n    font-weight: 700;\n    padding: 2px 8px;\n    border-radius: 20px;\n    letter-spacing: 0.03em;\n  }\n  .bsw-tag-ship {\n    background: #f0f0f0;\n    color: #555;\n  }\n  .bsw-tag-save {\n    background: #1a1a1a;\n    color: #fff;\n  }\n\n  /* Zone recettes */\n  .bsw-recipe-zone {\n    display: none;\n    margin-top: 11px;\n    padding-top: 11px;\n    border-top: 1px solid #ebebeb;\n  }\n  .bsw-option.selected .bsw-recipe-zone { display: block; }\n\n  .bsw-recipe-label {\n    font-size: 10.5px;\n    color: #aaa;\n    font-weight: 700;\n    text-transform: uppercase;\n    letter-spacing: 0.08em;\n    margin-bottom: 9px;\n  }\n\n  .bsw-sachet-row {\n    display: flex;\n    align-items: center;\n    gap: 9px;\n    margin-bottom: 7px;\n  }\n  .bsw-sachet-row:last-child { margin-bottom: 0; }\n\n  .bsw-sachet-label {\n    font-size: 12px;\n    color: #888;\n    min-width: 58px;\n    flex-shrink: 0;\n    font-weight: 600;\n  }\n\n  .bsw-sachet-btns { display: flex; gap: 6px; flex: 1; }\n\n  .bsw-recipe-btn {\n    flex: 1;\n    padding: 7px 0;\n    border-radius: 8px;\n    border: 1.5px solid #e5e5e5;\n    background: #fff;\n    font-size: 12px;\n    font-weight: 600;\n    color: #666;\n    cursor: pointer;\n    transition: border-color 0.15s, background 0.15s, color 0.15s;\n    text-align: center;\n  }\n  .bsw-recipe-btn:hover { border-color: #aaa; color: #333; }\n  .bsw-recipe-btn.active {\n    border-color: #1a1a1a;\n    background: #1a1a1a;\n    color: #fff;\n  }\n\n  /* Bouton principal */\n  .bsw-btn {\n    display: block;\n    width: 100%;\n    margin-top: 12px;\n    padding: 15px;\n    background: #1a1a1a;\n    color: #fff;\n    font-size: 14px;\n    font-weight: 700;\n    text-align: center;\n    border: none;\n    border-radius: 12px;\n    cursor: pointer;\n    letter-spacing: 0.03em;\n    transition: background 0.15s, transform 0.12s;\n    box-sizing: border-box;\n  }\n  .bsw-btn:hover { background: #333; }\n  .bsw-btn:active { transform: scale(0.98); }\n  .bsw-btn:disabled { background: #aaa; cursor: not-allowed; transform: none; }\n\n  /* Réassurance */\n  .bsw-reassurance {\n    display: flex;\n    justify-content: center;\n    gap: 16px;\n    margin-top: 10px;\n    flex-wrap: wrap;\n  }\n  .bsw-reassurance-item {\n    font-size: 11px;\n    color: #999;\n    display: flex;\n    align-items: center;\n    gap: 4px;\n  }\n  .bsw-reassurance-item svg {\n    width: 12px;\n    height: 12px;\n    flex-shrink: 0;\n  }\n\n  .bsw-saving {\n    text-align: center;\n    font-size: 11.5px;\n    color: #999;\n    margin-top: 7px;\n    min-height: 16px;\n  }\n  .bsw-saving b { color: #1a1a1a; font-weight: 700; }\n\n  .bsw-error {\n    text-align: center;\n    font-size: 12px;\n    color: #c0392b;\n    margin-top: 6px;\n    font-weight: 600;\n    display: none;\n  }\n</style>\n\n<div class=\"bsw\">\n\n  <div class=\"bsw-divider\">\n    <div class=\"bsw-divider-line\"></div>\n    <span class=\"bsw-divider-text\">Choisissez votre cure</span>\n    <div class=\"bsw-divider-line\"></div>\n  </div>\n\n  <div class=\"bsw-options\">\n\n    <!-- x1 -->\n    <div class=\"bsw-option selected\" data-qty=\"1\" data-discount=\"0\">\n      <div class=\"bsw-option-row\">\n        <div class=\"bsw-radio\"><div class=\"bsw-radio-dot\"></div></div>\n        <div class=\"bsw-info\">\n          <div class=\"bsw-qty\">Cure 1 mois</div>\n          <div class=\"bsw-per-unit bsw-per-unit-val\">—</div>\n        </div>\n        <div class=\"bsw-pricing\">\n          <span class=\"bsw-price bsw-price-val\">—</span>\n        </div>\n      </div>\n      <div class=\"bsw-recipe-zone\">\n        <div class=\"bsw-recipe-label\">Votre recette</div>\n        <div class=\"bsw-sachet-row\">\n          <span class=\"bsw-sachet-label\">Sachet 1</span>\n          <div class=\"bsw-sachet-btns\">\n            <button class=\"bsw-recipe-btn active\" data-recipe=\"fruitée\">🍋 Fruitée</button>\n            <button class=\"bsw-recipe-btn\" data-recipe=\"nature\">🌿 Nature</button>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <!-- x2 -->\n    <div class=\"bsw-option\" data-qty=\"2\" data-discount=\"8\">\n      <div class=\"bsw-option-row\">\n        <div class=\"bsw-radio\"><div class=\"bsw-radio-dot\"></div></div>\n        <div class=\"bsw-info\">\n          <div class=\"bsw-qty\">\n            Cure 2 mois\n            <span class=\"bsw-tag bsw-tag-ship\">Livraison offerte</span>\n            <span class=\"bsw-tag bsw-tag-save\">−8%</span>\n          </div>\n          <div class=\"bsw-per-unit bsw-per-unit-val\">—</div>\n        </div>\n        <div class=\"bsw-pricing\">\n          <span class=\"bsw-price bsw-price-val\">—</span>\n          <span class=\"bsw-original bsw-original-val\"></span>\n        </div>\n      </div>\n      <div class=\"bsw-recipe-zone\">\n        <div class=\"bsw-recipe-label\">Vos recettes</div>\n        <div class=\"bsw-sachet-row\">\n          <span class=\"bsw-sachet-label\">Sachet 1</span>\n          <div class=\"bsw-sachet-btns\">\n            <button class=\"bsw-recipe-btn active\" data-recipe=\"fruitée\">🍋 Fruitée</button>\n            <button class=\"bsw-recipe-btn\" data-recipe=\"nature\">🌿 Nature</button>\n          </div>\n        </div>\n        <div class=\"bsw-sachet-row\">\n          <span class=\"bsw-sachet-label\">Sachet 2</span>\n          <div class=\"bsw-sachet-btns\">\n            <button class=\"bsw-recipe-btn active\" data-recipe=\"fruitée\">🍋 Fruitée</button>\n            <button class=\"bsw-recipe-btn\" data-recipe=\"nature\">🌿 Nature</button>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <!-- x3 -->\n    <div class=\"bsw-option\" data-qty=\"3\" data-discount=\"16\">\n      <div class=\"bsw-badge\">Le plus populaire</div>\n      <div class=\"bsw-option-row\">\n        <div class=\"bsw-radio\"><div class=\"bsw-radio-dot\"></div></div>\n        <div class=\"bsw-info\">\n          <div class=\"bsw-qty\">\n            Cure 3 mois\n            <span class=\"bsw-tag bsw-tag-ship\">Livraison offerte</span>\n            <span class=\"bsw-tag bsw-tag-save\">−16%</span>\n          </div>\n          <div class=\"bsw-per-unit bsw-per-unit-val\">—</div>\n        </div>\n        <div class=\"bsw-pricing\">\n          <span class=\"bsw-price bsw-price-val\">—</span>\n          <span class=\"bsw-original bsw-original-val\"></span>\n        </div>\n      </div>\n      <div class=\"bsw-recipe-zone\">\n        <div class=\"bsw-recipe-label\">Vos recettes</div>\n        <div class=\"bsw-sachet-row\">\n          <span class=\"bsw-sachet-label\">Sachet 1</span>\n          <div class=\"bsw-sachet-btns\">\n            <button class=\"bsw-recipe-btn active\" data-recipe=\"fruitée\">🍋 Fruitée</button>\n            <button class=\"bsw-recipe-btn\" data-recipe=\"nature\">🌿 Nature</button>\n          </div>\n        </div>\n        <div class=\"bsw-sachet-row\">\n          <span class=\"bsw-sachet-label\">Sachet 2</span>\n          <div class=\"bsw-sachet-btns\">\n            <button class=\"bsw-recipe-btn active\" data-recipe=\"fruitée\">🍋 Fruitée</button>\n            <button class=\"bsw-recipe-btn\" data-recipe=\"nature\">🌿 Nature</button>\n          </div>\n        </div>\n        <div class=\"bsw-sachet-row\">\n          <span class=\"bsw-sachet-label\">Sachet 3</span>\n          <div class=\"bsw-sachet-btns\">\n            <button class=\"bsw-recipe-btn active\" data-recipe=\"fruitée\">🍋 Fruitée</button>\n            <button class=\"bsw-recipe-btn\" data-recipe=\"nature\">🌿 Nature</button>\n          </div>\n        </div>\n      </div>\n    </div>\n\n  </div>\n\n  <button class=\"bsw-btn\" id=\"bswBtn\">Ajouter au panier</button>\n  <p class=\"bsw-saving\" id=\"bswSaving\">&nbsp;</p>\n\n  <div class=\"bsw-reassurance\">\n    <span class=\"bsw-reassurance-item\">\n      <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z\"/></svg>\n      Paiement sécurisé\n    </span>\n    <span class=\"bsw-reassurance-item\">\n      <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z\"/><polyline points=\"9 22 9 12 15 12 15 22\"/></svg>\n      Marque française\n    </span>\n    <span class=\"bsw-reassurance-item\">\n      <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z\"/></svg>\n      Certifié AB Bio\n    </span>\n  </div>\n\n  <p class=\"bsw-error\" id=\"bswError\">⚠️ Une erreur est survenue, réessaie.</p>\n\n</div>\n\n<script>\n(function() {\n\n  function eur(n) {\n    return '€' + parseFloat(n).toFixed(2).replace('.', ',');\n  }\n\n  function getVariant(recipe) {\n    var key = recipe.toLowerCase().trim();\n    for (var k in BUNDLE_VARIANTS) {\n      if (k.indexOf(key) !== -1) return BUNDLE_VARIANTS[k];\n    }\n    return null;\n  }\n\n  function calcTotal(opt) {\n    var discount = parseInt(opt.dataset.discount) || 0;\n    var rows = opt.querySelectorAll('.bsw-sachet-row');\n    var full = 0;\n    rows.forEach(function(row) {\n      var active = row.querySelector('.bsw-recipe-btn.active');\n      var v = getVariant(active ? active.dataset.recipe : 'fruitée');\n      full += v ? v.price : 0;\n    });\n    var discounted = discount > 0\n      ? Math.round(full * (1 - discount / 100) * 100) / 100\n      : full;\n    return { full: full, discounted: discounted };\n  }\n\n  function refreshOption(opt) {\n    var p = calcTotal(opt);\n    var qty = parseInt(opt.dataset.qty);\n    opt.querySelector('.bsw-price-val').textContent = eur(p.discounted);\n    opt.querySelector('.bsw-per-unit-val').textContent = eur(p.discounted / qty) + ' / cure';\n    var origEl = opt.querySelector('.bsw-original-val');\n    if (origEl) origEl.textContent = p.full !== p.discounted ? eur(p.full) : '';\n  }\n\n  var btn    = document.getElementById('bswBtn');\n  var saving = document.getElementById('bswSaving');\n  var errEl  = document.getElementById('bswError');\n\n  function refreshBtn() {\n    var sel = document.querySelector('.bsw-option.selected');\n    if (!sel) return;\n    var p = calcTotal(sel);\n    var saved = Math.round((p.full - p.discounted) * 100) / 100;\n    btn.textContent = 'Ajouter au panier — ' + eur(p.discounted);\n    saving.innerHTML = saved > 0\n      ? 'Tu économises <b>' + eur(saved) + '</b> sur cette commande'\n      : '&nbsp;';\n  }\n\n  function refreshAll() {\n    document.querySelectorAll('.bsw-option').forEach(function(o) { refreshOption(o); });\n    refreshBtn();\n  }\n\n  document.querySelectorAll('.bsw-option').forEach(function(opt) {\n    opt.addEventListener('click', function(e) {\n      if (e.target.classList.contains('bsw-recipe-btn')) return;\n      document.querySelectorAll('.bsw-option').forEach(function(o) { o.classList.remove('selected'); });\n      opt.classList.add('selected');\n      refreshBtn();\n    });\n  });\n\n  document.querySelectorAll('.bsw-recipe-btn').forEach(function(rb) {\n    rb.addEventListener('click', function(e) {\n      e.stopPropagation();\n      var row = rb.closest('.bsw-sachet-row');\n      row.querySelectorAll('.bsw-recipe-btn').forEach(function(b) { b.classList.remove('active'); });\n      rb.classList.add('active');\n      var parentOpt = rb.closest('.bsw-option');\n      if (!parentOpt.classList.contains('selected')) {\n        document.querySelectorAll('.bsw-option').forEach(function(o) { o.classList.remove('selected'); });\n        parentOpt.classList.add('selected');\n      }\n      refreshOption(parentOpt);\n      refreshBtn();\n    });\n  });\n\n  btn.addEventListener('click', function() {\n    var sel = document.querySelector('.bsw-option.selected');\n    if (!sel) return;\n\n    errEl.style.display = 'none';\n\n    var counts = {};\n    sel.querySelectorAll('.bsw-sachet-row').forEach(function(row) {\n      var active = row.querySelector('.bsw-recipe-btn.active');\n      var v = getVariant(active ? active.dataset.recipe : 'fruitée');\n      if (!v) return;\n      counts[v.id] = (counts[v.id] || 0) + 1;\n    });\n\n    var items = Object.keys(counts).map(function(id) {\n      return { id: parseInt(id), quantity: counts[id] };\n    });\n\n    btn.disabled = true;\n    btn.textContent = 'Ajout en cours…';\n\n    var cartDrawer = document.querySelector('cart-drawer');\n    var sectionsParam = cartDrawer\n      ? cartDrawer.getSectionsToRender().map(function(s) { return s.id; })\n      : ['cart-drawer', 'cart-icon-bubble'];\n\n    fetch('/cart/add.js', {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },\n      body: JSON.stringify({\n        items: items,\n        sections: sectionsParam,\n        sections_url: window.location.pathname\n      })\n    })\n    .then(function(r) {\n      if (!r.ok) throw new Error('HTTP ' + r.status);\n      return r.json();\n    })\n    .then(function(response) {\n      btn.textContent = '✓ Ajouté au panier !';\n      btn.style.background = '#2d7a3a';\n\n      if (cartDrawer) cartDrawer.renderContents(response);\n\n      if (typeof publish === 'function' && typeof PUB_SUB_EVENTS !== 'undefined') {\n        publish(PUB_SUB_EVENTS.cartUpdate, { source: 'product-form', cartData: response });\n      }\n\n      setTimeout(function() {\n        btn.disabled = false;\n        btn.style.background = '';\n        refreshBtn();\n      }, 2200);\n    })\n    .catch(function(err) {\n      console.error('Bundle error:', err);\n      btn.disabled = false;\n      btn.style.background = '';\n      btn.textContent = '⚠️ Erreur — réessaie';\n      errEl.style.display = 'block';\n      setTimeout(function() {\n        refreshBtn();\n        errEl.style.display = 'none';\n      }, 3000);\n    });\n  });\n\n  refreshAll();\n})();\n</script>"
          }
