        "custom_liquid_XAJGaR": {
          "type": "custom_liquid",
          "settings": {
            "custom_liquid": "{% comment %}\n  ✅ VERSION CAROUSEL — plusieurs avis qui slidenet automatiquement\n  ➡ Modifie les avis dans le tableau JS en bas du fichier\n{% endcomment %}\n\n<style>\n  .rc-wrap {\n    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;\n    margin: 12px 0 16px;\n    width: 100%;\n    position: relative;\n  }\n\n  .rc-track-outer {\n    overflow: hidden;\n    border-radius: 12px;\n    border: 1px solid #e8e8e8;\n    background: #f8f8f8;\n  }\n\n  .rc-track {\n    display: flex;\n    transition: transform 0.55s cubic-bezier(0.65, 0, 0.35, 1);\n    will-change: transform;\n  }\n\n  .rc-slide {\n    min-width: 100%;\n    display: flex;\n    align-items: flex-start;\n    gap: 12px;\n    padding: 14px 40px 14px 14px;\n    box-sizing: border-box;\n    text-decoration: none;\n    color: inherit;\n  }\n\n  /* Avatar */\n  .rc-avatar {\n    flex-shrink: 0;\n    width: 42px;\n    height: 42px;\n    border-radius: 50%;\n    background: #ddd;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    font-size: 14px;\n    font-weight: 700;\n    color: #777;\n    text-transform: uppercase;\n    overflow: hidden;\n  }\n\n  .rc-avatar img {\n    width: 100%;\n    height: 100%;\n    object-fit: cover;\n  }\n\n  /* Contenu */\n  .rc-content {\n    flex: 1;\n    min-width: 0;\n  }\n\n  .rc-header {\n    display: flex;\n    align-items: center;\n    gap: 8px;\n    flex-wrap: wrap;\n    margin-bottom: 4px;\n  }\n\n  .rc-name {\n    font-size: 13px;\n    font-weight: 700;\n    color: #1a1a1a;\n  }\n\n  .rc-stars {\n    display: flex;\n    gap: 1px;\n  }\n\n  .rc-stars svg {\n    width: 12px;\n    height: 12px;\n  }\n\n  .rc-text {\n    font-size: 12.5px;\n    color: #555;\n    line-height: 1.5;\n    font-style: italic;\n    margin: 0;\n    display: -webkit-box;\n    -webkit-line-clamp: 3;\n    -webkit-box-orient: vertical;\n    overflow: hidden;\n  }\n\n  /* Flèche navigation */\n  .rc-arrow {\n    position: absolute;\n    top: 50%;\n    transform: translateY(-50%);\n    width: 28px;\n    height: 28px;\n    border-radius: 50%;\n    background: white;\n    border: 1px solid #e0e0e0;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    cursor: pointer;\n    z-index: 2;\n    box-shadow: 0 1px 4px rgba(0,0,0,0.08);\n    transition: box-shadow 0.15s;\n  }\n\n  .rc-arrow:hover {\n    box-shadow: 0 2px 8px rgba(0,0,0,0.14);\n  }\n\n  .rc-arrow svg {\n    width: 14px;\n    height: 14px;\n    color: #555;\n  }\n\n  .rc-arrow-right {\n    right: 6px;\n  }\n\n  .rc-arrow-left {\n    left: 6px;\n    display: none; /* caché par défaut sur mobile, visible si JS actif */\n  }\n\n  /* Dots */\n  .rc-dots {\n    display: flex;\n    justify-content: center;\n    gap: 5px;\n    margin-top: 8px;\n  }\n\n  .rc-dot {\n    width: 6px;\n    height: 6px;\n    border-radius: 50%;\n    background: #ddd;\n    transition: background 0.3s, transform 0.3s;\n    cursor: pointer;\n  }\n\n  .rc-dot.active {\n    background: #888;\n    transform: scale(1.25);\n  }\n\n  /* Barre de progression */\n  .rc-progress-bar {\n    height: 2px;\n    background: #eee;\n    border-radius: 0 0 12px 12px;\n    overflow: hidden;\n  }\n\n  .rc-progress-fill {\n    height: 100%;\n    background: #1a1a1a;\n    width: 0%;\n    transition: width linear;\n  }\n\n  @media (max-width: 480px) {\n    .rc-slide { padding: 12px 38px 12px 12px; gap: 10px; }\n    .rc-avatar { width: 38px; height: 38px; font-size: 13px; }\n    .rc-name { font-size: 12.5px; }\n    .rc-text { font-size: 12px; }\n  }\n</style>\n\n<div class=\"rc-wrap\" id=\"reviewCarousel\">\n\n  <div class=\"rc-track-outer\">\n    <div class=\"rc-track\" id=\"rcTrack\">\n      <!-- Les slides sont injectées en JS -->\n    </div>\n    <div class=\"rc-progress-bar\"><div class=\"rc-progress-fill\" id=\"rcProgress\"></div></div>\n  </div>\n\n  <button class=\"rc-arrow rc-arrow-left\" id=\"rcPrev\" aria-label=\"Avis précédent\">\n    <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n      <path d=\"M15 18l-6-6 6-6\"/>\n    </svg>\n  </button>\n\n  <button class=\"rc-arrow rc-arrow-right\" id=\"rcNext\" aria-label=\"Avis suivant\">\n    <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n      <path d=\"M9 18l6-6-6-6\"/>\n    </svg>\n  </button>\n\n  <div class=\"rc-dots\" id=\"rcDots\"></div>\n</div>\n\n<script>\n(function() {\n\n  // ============================================================\n  //  ✏️  MODIFIE TES AVIS ICI\n  // ============================================================\n var reviews = [\n  {\n    name: \"Clara B.\",\n    stars: 5,\n    text: \"Je ne m’attendais pas à ça… ventre plus plat en quelques jours et surtout une vraie sensation de légèreté après les repas. Très efficace.\"\n  },\n  {\n    name: \"Nina R.\",\n    stars: 5,\n    text: \"Enfin un thé qui fait plus que drainer. Je sens que ça agit vraiment sur mon corps, surtout au niveau du ventre. Et le goût est top.\"\n  },\n  {\n    name: \"Sarah M.\",\n    stars: 5,\n    text: \"Routine hyper simple à tenir, et les résultats sont là. Moins de fringales, moins de gonflement, je me sens clairement mieux.\"\n  },\n  {\n    name: \"Laura K.\",\n    stars: 4,\n    text: \"Très bonne surprise. Doux, agréable à boire et sans effet brutal. Parfait pour relancer doucement le métabolisme.\"\n  }\n];\n  // ============================================================\n\n  var DURATION = 5000; // 5 secondes par slide\n\n  var track    = document.getElementById('rcTrack');\n  var dotsWrap = document.getElementById('rcDots');\n  var progress = document.getElementById('rcProgress');\n  var btnPrev  = document.getElementById('rcPrev');\n  var btnNext  = document.getElementById('rcNext');\n\n  var current  = 0;\n  var total    = reviews.length;\n  var timer    = null;\n  var progTimer = null;\n\n  function starsSVG(n) {\n    var html = '';\n    for (var i = 1; i <= 5; i++) {\n      var fill = i <= n ? '#f59e0b' : '#e5e7eb';\n      html += '<svg viewBox=\"0 0 20 20\" fill=\"' + fill + '\" xmlns=\"http://www.w3.org/2000/svg\"><path d=\"M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z\"/></svg>';\n    }\n    return html;\n  }\n\n  function initials(name) {\n    return name.replace('.', '').trim().split(' ').map(function(w){ return w[0]; }).join('').slice(0,2);\n  }\n\n  // Construire les slides\n  reviews.forEach(function(r, idx) {\n    var slide = document.createElement('a');\n    slide.className = 'rc-slide';\n    slide.href = '#avis';\n    slide.innerHTML =\n      '<div class=\"rc-avatar\">' + initials(r.name) + '</div>' +\n      '<div class=\"rc-content\">' +\n        '<div class=\"rc-header\">' +\n          '<span class=\"rc-name\">' + r.name + '</span>' +\n          '<div class=\"rc-stars\">' + starsSVG(r.stars) + '</div>' +\n        '</div>' +\n        '<p class=\"rc-text\">\\u201c' + r.text + '\\u201d</p>' +\n      '</div>';\n    track.appendChild(slide);\n\n    // Dot\n    var dot = document.createElement('div');\n    dot.className = 'rc-dot' + (idx === 0 ? ' active' : '');\n    dot.addEventListener('click', function() { goTo(idx); });\n    dotsWrap.appendChild(dot);\n  });\n\n  // Afficher les flèches si > 1 avis\n  if (total > 1) {\n    btnPrev.style.display = 'flex';\n  }\n\n  function updateDots() {\n    var dots = dotsWrap.querySelectorAll('.rc-dot');\n    dots.forEach(function(d, i) {\n      d.classList.toggle('active', i === current);\n    });\n  }\n\n  function startProgress() {\n    clearInterval(progTimer);\n    progress.style.transition = 'none';\n    progress.style.width = '0%';\n    // force reflow\n    progress.offsetWidth;\n    progress.style.transition = 'width ' + DURATION + 'ms linear';\n    progress.style.width = '100%';\n  }\n\n  function goTo(idx) {\n    current = (idx + total) % total;\n    track.style.transform = 'translateX(-' + (current * 100) + '%)';\n    updateDots();\n    clearTimeout(timer);\n    startProgress();\n    timer = setTimeout(function() { goTo(current + 1); }, DURATION);\n  }\n\n  btnNext.addEventListener('click', function() { goTo(current + 1); });\n  btnPrev.addEventListener('click', function() { goTo(current - 1); });\n\n  // Pause au survol\n  var wrap = document.getElementById('reviewCarousel');\n  wrap.addEventListener('mouseenter', function() {\n    clearTimeout(timer);\n    clearInterval(progTimer);\n    progress.style.transition = 'none';\n  });\n  wrap.addEventListener('mouseleave', function() {\n    goTo(current);\n  });\n\n  // Swipe mobile\n  var touchStartX = 0;\n  track.addEventListener('touchstart', function(e) { touchStartX = e.touches[0].clientX; }, { passive: true });\n  track.addEventListener('touchend', function(e) {\n    var dx = e.changedTouches[0].clientX - touchStartX;\n    if (Math.abs(dx) > 40) { dx < 0 ? goTo(current + 1) : goTo(current - 1); }\n  }, { passive: true });\n\n  // Démarrage\n  goTo(0);\n\n})();\n</script>"
