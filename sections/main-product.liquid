                  <button class="bsw-btn" id="bswBtn-{{ block.id }}">Ajouter au panier</button>
                  <p class="bsw-saving" id="bswSaving-{{ block.id }}">&nbsp;</p>
                  <p class="bsw-error" id="bswError-{{ block.id }}">⚠️ Une erreur est survenue, réessaie.</p>
                </div>
                <script>
                (function() {
                  var BUNDLE_VARIANTS = BUNDLE_VARIANTS_{{ block.id | replace: "-", "_" }};
                  var wrap = document.getElementById('bsw-{{ block.id }}');
                  var btn = document.getElementById('bswBtn-{{ block.id }}');
                  var saving = document.getElementById('bswSaving-{{ block.id }}');
                  var errEl = document.getElementById('bswError-{{ block.id }}');
                  function eur(n) { return '€' + parseFloat(n).toFixed(2).replace('.', ','); }
                  function getVariant(recipe) {
                    var key = recipe.toLowerCase().trim();
                    for (var k in BUNDLE_VARIANTS) { if (k.indexOf(key) !== -1) return BUNDLE_VARIANTS[k]; }
                    return null;
                  }
                  function calcTotal(opt) {
                    var discount = parseInt(opt.dataset.discount) || 0;
                    var rows = opt.querySelectorAll('.bsw-sachet-row');
                    var full = 0;
                    rows.forEach(function(row) {
                      var active = row.querySelector('.bsw-recipe-btn.active');
                      var v = getVariant(active ? active.dataset.recipe : 'fruitée');
                      full += v ? v.price : 0;
                    });
                    var discounted = discount > 0 ? Math.round(full * (1 - discount / 100) * 100) / 100 : full;
                    return { full: full, discounted: discounted };
                  }
                  function refreshOption(opt) {
                    var p = calcTotal(opt);
                    var qty = parseInt(opt.dataset.qty);
                    opt.querySelector('.bsw-price-val').textContent = eur(p.discounted);
                    opt.querySelector('.bsw-per-unit-val').textContent = eur(p.discounted / qty) + ' / cure';
                    var origEl = opt.querySelector('.bsw-original-val');
                    if (origEl) origEl.textContent = p.full !== p.discounted ? eur(p.full) : '';
                  }
                  function refreshBtn() {
                    var sel = wrap.querySelector('.bsw-option.selected');
                    if (!sel) return;
                    var p = calcTotal(sel);
                    var saved = Math.round((p.full - p.discounted) * 100) / 100;
                    btn.textContent = 'Ajouter au panier — ' + eur(p.discounted);
                    saving.innerHTML = saved > 0 ? 'Tu économises <b>' + eur(saved) + '</b> sur cette commande' : '&nbsp;';
                  }
                  function refreshAll() { wrap.querySelectorAll('.bsw-option').forEach(function(o) { refreshOption(o); }); refreshBtn(); }
                  wrap.querySelectorAll('.bsw-option').forEach(function(opt) {
                    opt.addEventListener('click', function(e) {
                      if (e.target.classList.contains('bsw-recipe-btn')) return;
                      wrap.querySelectorAll('.bsw-option').forEach(function(o) { o.classList.remove('selected'); });
                      opt.classList.add('selected'); refreshBtn();
                    });
                  });
                  wrap.querySelectorAll('.bsw-recipe-btn').forEach(function(rb) {
                    rb.addEventListener('click', function(e) {
                      e.stopPropagation();
                      var row = rb.closest('.bsw-sachet-row');
                      row.querySelectorAll('.bsw-recipe-btn').forEach(function(b) { b.classList.remove('active'); });
                      rb.classList.add('active');
                      var parentOpt = rb.closest('.bsw-option');
                      if (!parentOpt.classList.contains('selected')) {
                        wrap.querySelectorAll('.bsw-option').forEach(function(o) { o.classList.remove('selected'); });
                        parentOpt.classList.add('selected');
                      }
                      refreshOption(parentOpt); refreshBtn();
                    });
                  });
                  btn.addEventListener('click', function() {
                    var sel = wrap.querySelector('.bsw-option.selected');
                    if (!sel) return;
                    errEl.style.display = 'none';
                    var counts = {};
                    sel.querySelectorAll('.bsw-sachet-row').forEach(function(row) {
                      var active = row.querySelector('.bsw-recipe-btn.active');
                      var v = getVariant(active ? active.dataset.recipe : 'fruitée');
                      if (!v) return;
                      counts[v.id] = (counts[v.id] || 0) + 1;
                    });
                    var items = Object.keys(counts).map(function(id) { return { id: parseInt(id), quantity: counts[id] }; });
                    btn.disabled = true; btn.textContent = 'Ajout en cours…';
                    var cartDrawer = document.querySelector('cart-drawer');
                    var sectionsParam = cartDrawer ? cartDrawer.getSectionsToRender().map(function(s) { return s.id; }) : ['cart-drawer', 'cart-icon-bubble'];
                    fetch('/cart/add.js', {
                      method: 'POST',
                      headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
                      body: JSON.stringify({ items: items, sections: sectionsParam, sections_url: window.location.pathname })
                    })
                    .then(function(r) { if (!r.ok) throw new Error('HTTP ' + r.status); return r.json(); })
                    .then(function(response) {
                      btn.textContent = '✓ Ajouté !'; btn.style.background = '#2d7a3a';
                      if (cartDrawer) { cartDrawer.renderContents(response); }
                      if (typeof publish === 'function' && typeof PUB_SUB_EVENTS !== 'undefined') {
                        publish(PUB_SUB_EVENTS.cartUpdate, { source: 'product-form', cartData: response });
                      }
                      setTimeout(function() { btn.disabled = false; btn.style.background = ''; refreshBtn(); }, 2200);
                    })
                    .catch(function(err) {
                      console.error('Bundle error:', err);
                      btn.disabled = false; btn.style.background = '#c0392b'; btn.textContent = '⚠️ Erreur — réessaie';
                      errEl.style.display = 'block';
                      setTimeout(function() { btn.style.background = ''; refreshBtn(); errEl.style.display = 'none'; }, 3000);
                    });
                  });
                  refreshAll();
                })();
                </script>
            {%- endcase -%}
          {%- endfor -%}
          {%- endfor -%}
          <a href="{{ product.url }}" class="link product__view-details animate-arrow">
            {{ 'products.product.view_full_details' | t }}
            {{- 'icon-arrow.svg' | inline_asset_content -}}
          </a>
        </section>
      </div>
    </div>

    {% render 'product-media-modal', variant_images: variant_images %}

    {% assign popups = section.blocks | where: 'type', 'popup' %}
    {%- for block in popups -%}
      <modal-dialog id="PopupModal-{{ block.id }}" class="product-popup-modal" {{ block.shopify_attributes }}>
        <div
          role="dialog"
          aria-label="{{ block.settings.text }}"
          aria-modal="true"
          class="product-popup-modal__content"
          tabindex="-1"
        >
          <button
            id="ModalClose-{{ block.id }}"
            type="button"
            class="product-popup-modal__toggle"
            aria-label="{{ 'accessibility.close' | t }}"
          >
            {{- 'icon-close.svg' | inline_asset_content -}}
          </button>
          <div class="product-popup-modal__content-info">
            <h1 class="h2">{{ block.settings.page.title | escape }}</h1>
            {{ block.settings.page.content }}
          </div>
        </div>
      </modal-dialog>
    {%- endfor -%}

    {%- if product.media.size > 0 -%}
      <script src="{{ 'product-modal.js' | asset_url }}" defer="defer"></script>
      <script src="{{ 'media-gallery.js' | asset_url }}" defer="defer"></script>
    {%- endif -%}

    {%- if first_3d_model -%}
      <script type="application/json" id="ProductJSON-{{ product.id }}">
        {{ product.media | where: 'media_type', 'model' | json }}
      </script>
      <script src="{{ 'product-model.js' | asset_url }}" defer></script>
    {%- endif -%}

    {%- liquid
      if product.selected_or_first_available_variant.featured_media
        assign seo_media = product.selected_or_first_available_variant.featured_media
      else
        assign seo_media = product.featured_media
      endif
    -%}

    <script type="application/ld+json">
      {{ product | structured_data }}
    </script>
  </div>
</product-info>

