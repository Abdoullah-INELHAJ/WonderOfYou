                -%}
                <style>
                  .rc-wrap { font-family: inherit; margin: 12px 0 16px; width: 100%; position: relative; }
                  .rc-track-outer { overflow: hidden; border-radius: 12px; border: 1px solid #e8e8e8; background: #f8f8f8; }
                  .rc-track { display: flex; transition: transform 0.55s cubic-bezier(0.65, 0, 0.35, 1); will-change: transform; }
                  .rc-slide { min-width: 100%; display: flex; align-items: flex-start; gap: 12px; padding: 14px 40px 14px 14px; box-sizing: border-box; text-decoration: none; color: inherit; }
                  .rc-avatar { flex-shrink: 0; width: 42px; height: 42px; border-radius: 50%; background: #ddd; display: flex; align-items: center; justify-content: center; font-size: 14px; font-weight: 700; color: #777; text-transform: uppercase; overflow: hidden; }
                  .rc-avatar img { width: 100%; height: 100%; object-fit: cover; }
                  .rc-content { flex: 1; min-width: 0; }
                  .rc-header { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; margin-bottom: 4px; }
                  .rc-name { font-size: 13px; font-weight: 700; color: #1a1a1a; }
                  .rc-stars { display: flex; gap: 1px; }
                  .rc-stars svg { width: 12px; height: 12px; }
                  .rc-text { font-size: 12.5px; color: #555; line-height: 1.5; font-style: italic; margin: 0; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
                  .rc-arrow { position: absolute; top: 50%; transform: translateY(-50%); width: 28px; height: 28px; border-radius: 50%; background: white; border: 1px solid #e0e0e0; display: flex; align-items: center; justify-content: center; cursor: pointer; z-index: 2; box-shadow: 0 1px 4px rgba(0,0,0,0.08); transition: box-shadow 0.15s; pointer-events: auto; }
                  .rc-arrow:hover { box-shadow: 0 2px 8px rgba(0,0,0,0.14); }
                  .rc-arrow svg { width: 14px; height: 14px; color: #555; }
                  .rc-arrow-right { right: 6px; }
                  .rc-arrow-left { left: 6px; display: none; }
                  .rc-dots { display: flex; justify-content: center; gap: 5px; margin-top: 8px; }
                  .rc-dot { width: 6px; height: 6px; border-radius: 50%; background: #ddd; transition: background 0.3s, transform 0.3s; cursor: pointer; }
                  .rc-dot.active { background: #888; transform: scale(1.25); }
                  .rc-progress-bar { height: 2px; background: #eee; border-radius: 0 0 12px 12px; overflow: hidden; }
                  .rc-progress-fill { height: 100%; background: #1a1a1a; width: 0%; transition: width linear; }
                  @media (max-width: 480px) { .rc-slide { padding: 12px 38px 12px 12px; gap: 10px; } .rc-avatar { width: 38px; height: 38px; font-size: 13px; } .rc-name { font-size: 12.5px; } .rc-text { font-size: 12px; } }
                </style>

                <div class="rc-wrap" id="reviewCarousel-{{ block.id }}">
                  <div class="rc-track-outer">
                    <div class="rc-track" id="rcTrack-{{ block.id }}"></div>
                    <div class="rc-progress-bar"><div class="rc-progress-fill" id="rcProgress-{{ block.id }}"></div></div>
                  </div>
                  <button class="rc-arrow rc-arrow-left" id="rcPrev-{{ block.id }}" aria-label="Avis précédent">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
                  </button>
                  <button class="rc-arrow rc-arrow-right" id="rcNext-{{ block.id }}" aria-label="Avis suivant">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
                  </button>
                  <div class="rc-dots" id="rcDots-{{ block.id }}"></div>
                </div>

                <script>
                (function() {
                  var reviews = [
                    { name: "Marie L.", stars: 5, text: "J'avais peur que ça ne fasse rien au bout d'une semaine... mais dès le 4ème jour mon ventre était visiblement moins gonflé. Je me sens plus légère après les repas, c'est bluffant !" },
                    { name: "Sophie R.", stars: 5, text: "Le goût pêche-citron est vraiment agréable, pas du tout amer comme d'autres thés que j'avais essayés. Je le bois le soir et je dors mieux aussi. Ma cure de 28 jours touche à sa fin et je recommande." },
                    { name: "Camille D.", stars: 5, text: "J'étais sceptique sur la perte de poids naturelle mais j'ai quand même perdu 2 kg en un mois sans changer mon alimentation. Le transit s'est vraiment amélioré dès la première semaine !" },
                    { name: "Laura M.", stars: 4, text: "Très bonne odeur à l'ouverture, l'infusion est douce et pas du tout écoeurante. Je sens que mon corps est moins lourd, surtout le matin. Je vais renouveler la commande sans hésiter." }
                  ];
                  var DURATION = {{ duration }};
                  var track = document.getElementById('rcTrack-{{ block.id }}');
                  var dotsWrap = document.getElementById('rcDots-{{ block.id }}');
                  var progress = document.getElementById('rcProgress-{{ block.id }}');
                  var btnPrev = document.getElementById('rcPrev-{{ block.id }}');
                  var btnNext = document.getElementById('rcNext-{{ block.id }}');
                  var current = 0;
                  var total = reviews.length;
                  var timer = null;
                  function starsSVG(n) {
                    var html = '';
                    for (var i = 1; i <= 5; i++) {
                      var fill = i <= n ? '#f59e0b' : '#e5e7eb';
                      html += '<svg viewBox="0 0 20 20" fill="' + fill + '" xmlns="http://www.w3.org/2000/svg"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>';
                    }
                    return html;
                  }
                  function initials(name) { return name.replace('.', '').trim().split(' ').map(function(w){ return w[0]; }).join('').slice(0,2); }
                  reviews.forEach(function(r, idx) {
                    var slide = document.createElement('a'); slide.className = 'rc-slide'; slide.href = '#avis';
                    slide.innerHTML = '<div class="rc-avatar">' + initials(r.name) + '</div><div class="rc-content"><div class="rc-header"><span class="rc-name">' + r.name + '</span><div class="rc-stars">' + starsSVG(r.stars) + '</div></div><p class="rc-text">\u201c' + r.text + '\u201d</p></div>';
                    track.appendChild(slide);
                    var dot = document.createElement('div'); dot.className = 'rc-dot' + (idx === 0 ? ' active' : '');
                    dot.addEventListener('click', function() { goTo(idx); }); dotsWrap.appendChild(dot);
                  });
                  if (total > 1) { btnPrev.style.display = 'flex'; }
                  function updateDots() { dotsWrap.querySelectorAll('.rc-dot').forEach(function(d, i) { d.classList.toggle('active', i === current); }); }
                  function startProgress() { progress.style.transition = 'none'; progress.style.width = '0%'; progress.offsetWidth; progress.style.transition = 'width ' + DURATION + 'ms linear'; progress.style.width = '100%'; }
                  function goTo(idx) {
                    current = (idx + total) % total; track.style.transform = 'translateX(-' + (current * 100) + '%)';
                    updateDots(); clearTimeout(timer); startProgress();
                    timer = setTimeout(function() { goTo(current + 1); }, DURATION);
                  }
                  btnNext.addEventListener('click', function() { goTo(current + 1); });
                  btnPrev.addEventListener('click', function() { goTo(current - 1); });
                  var wrap = document.getElementById('reviewCarousel-{{ block.id }}');
                  wrap.addEventListener('mouseenter', function() { clearTimeout(timer); progress.style.transition = 'none'; });
                  wrap.addEventListener('mouseleave', function() { goTo(current); });
                  var touchStartX = 0;
                  track.addEventListener('touchstart', function(e) { touchStartX = e.touches[0].clientX; }, { passive: true });
                  track.addEventListener('touchend', function(e) { var dx = e.changedTouches[0].clientX - touchStartX; if (Math.abs(dx) > 40) { dx < 0 ? goTo(current + 1) : goTo(current - 1); } }, { passive: true });
                  goTo(0);
                })();
                </script>
